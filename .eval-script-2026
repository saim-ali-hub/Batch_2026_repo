###################################################################################################
check_swap() {
    echo "Checking Q19: Swap Configuration ......."

    # Ask user input
    read -p "Enter swap device or partition (e.g., /dev/sdb1): " swap_dev

    # Validate input
    [ -z "$swap_dev" ] && { echo "No device entered. Exiting."; return; }

    # Check if swap is active
    swapon --show | grep -q "$swap_dev"
    if [ $? -ne 0 ]; then
        echo -e "\e[31mSwap device $swap_dev not active: Fail\e[0m\n"
        return
    fi

    # Get size dynamically
    swap_size=$(lsblk -b "$swap_dev" | awk 'NR==2 {print int($4/1024/1024)}')

    if [ "$swap_size" -ge 500 ] && [ "$swap_size" -le 520 ]; then
        echo -e "\e[32mSwap size ${swap_size}MB: Pass\e[0m"
    else
        echo -e "\e[31mSwap size ${swap_size}MB: Fail\e[0m"
    fi

    # Check persistence
    grep -q "$swap_dev" /etc/fstab
    if [ $? -eq 0 ]; then
        echo -e "\e[32mPersistent swap entry: Pass\e[0m\n"
    else
        echo -e "\e[31mMissing fstab entry: Fail\e[0m\n"
    fi
}
################################################################################
check_lv1_create_extend() {
    echo "Checking Q20: LVM Create & Extend (/app1) ......."

    mp="/app1"
    vg="vg1"
    lv="lv1"

    mount | grep -q " $mp "
    mp_st=$?

    if [ $mp_st -ne 0 ]; then
        echo -e "\e[31mMount point $mp not found: Fail\e[0m\n"
        return
    fi

    vgs | grep -w "$vg" >/dev/null 2>&1 || {
        echo -e "\e[31mVG $vg missing: Fail\e[0m\n"
        return
    }

    lvs | grep -w "$lv" >/dev/null 2>&1 || {
        echo -e "\e[31mLV $lv missing: Fail\e[0m\n"
        return
    }

    fs_size=$(df -m "$mp" | awk 'NR==2 {print $2}')

    if [ "$fs_size" -ge 450 ] && [ "$fs_size" -le 500 ]; then
        echo -e "\e[32mFilesystem size ${fs_size}M: Pass\e[0m\n"
    else
        echo -e "\e[31mFilesystem size is not ${fs_size}M: Fail\e[0m\n"
    fi
}
################################################################################
check_lv2_extents() {
    echo "Checking Q22: LVM with Specific Extents (/app2) ......."

    vg="vg2"
    lv="lv2"
    mp="/app2"
    req_pe=8
    req_le=50

    vgs | grep -w "$vg" >/dev/null 2>&1 || {
        echo -e "\e[31mVG $vg missing: Fail\e[0m\n"
        return
    }

    pe_size=$(vgdisplay "$vg" | awk '/PE Size/ {print int($3)}')
    if [ "$pe_size" -eq "$req_pe" ]; then
        echo -e "\e[32mPE Size = ${pe_size}MiB: Pass\e[0m"
    else
        echo -e "\e[31mPE Size is not equal ${pe_size}MiB: Fail\e[0m"
    fi

    le_count=$(lvdisplay /dev/$vg/$lv 2>/dev/null | awk '/Current LE/ {print $3}')
    if [ "$le_count" -eq "$req_le" ]; then
        echo -e "\e[32mLE Count = ${le_count} → Pass\e[0m"
    else
        echo -e "\e[31mLE Count is not ${le_count}: Fail\e[0m"
    fi

    mount | grep -q " $mp "
    if [ $? -eq 0 ]; then
        echo -e "\e[32mMounted on $mp: Pass\e[0m\n"
    else
        echo -e "\e[31mMount point $mp is missing: Fail\e[0m\n"
    fi
}
################################################################################
check_lv3_shrink() {
    echo "Checking Q22: LVM Shrink (/app3) ......."

    mp="/app3"
    vg="vg3"
    lv="lv3"

    mount | grep -q " $mp "
    if [ $? -ne 0 ]; then
        echo -e "\e[31mMount point $mp is missing: Fail\e[0m\n"
        return
    fi

    fs_size=$(df -m "$mp" | awk 'NR==2 {print $2}')

    if [ "$fs_size" -ge 250 ] && [ "$fs_size" -le 300 ]; then
