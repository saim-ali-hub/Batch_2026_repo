    else
        echo -e "\e[31m24(iv) → Fail\e[0m\n"
    fi

    # v) Program 'myprogram' existence
    if [ -f /usr/local/bin/myprogram ]; then
        # Optional: check if program contains a find command for group 'developers'
        if grep -q "developers" /usr/local/bin/myprogram; then
