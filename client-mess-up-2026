#!/bin/bash

# Root check
if [ "$(id -u)" -ne 0 ]; then
    echo "Please run as root"
    exit 1
fi

# Move script if present locally
if [ -f ".client-mess-up-2026" ]; then
    mv -f .client-mess-up-2026 /usr/share/.client-mess-up-2026 2>/dev/null
fi

# Verify script exists
if [ ! -f /usr/share/.client-mess-up-2026 ]; then
    echo "Error: /usr/share/.client-mess-up-2026 not found"
    exit 1
fi

# Source the script SAFELY
set +e
source /usr/share/.client-mess-up-2026 2>/dev/null
set +e

# Menu loop
echo "Select an option:"
echo "1) changing_rootpw_repos_chrony"
echo "2) changing_other_configurations"
echo "3) Configure_LVM"
echo "4) Configure_container"
echo "q) Quit"

while true; do
    read -p "Enter choice (1, 2, 3, 4 q): " code
    echo ""

    case "$code" in
        1)
            changing_rootpw_repos_chrony
            read -p "Reboot system now? (y/n): " ans
            [[ "$ans" == "y" ]] && shutdown -r now
            ;;
        2)
            changing_other_configurations
            ;;
        3) 
            Configure_LVM 
            ;;
         4) 
            Configure_container
            ;;
        q|Q)
            echo "Exiting... Goodbye!"
            exit 0
            ;;
        *)
            echo "Invalid option. Try again."
            ;;
    esac
done
)
