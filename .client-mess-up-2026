Configure_LVM() {
echo "RUNNING TASK 6 ......................."

mountpoint -q /app1 && umount /app1 || true
    sed -i '\|/app1|d' /etc/fstab || true
    pv_list_vg1=$(pvs --noheadings -o pv_name,vg_name | awk '$2=="vg1"{print $1}')
    lvremove -y /dev/vg1/lv1 &>/dev/null || true
    vgremove -y vg1 &>/dev/null || true
    for pv in $pv_list_vg1; do
        pvremove -y "$pv" &>/dev/null || true
    done

mountpoint -q /app2 && umount /app2 || true
    sed -i '\|/app2|d' /etc/fstab || true
    pv_list_vg2=$(pvs --noheadings -o pv_name,vg_name | awk '$2=="vg2"{print $1}')
    lvremove -y /dev/vg2/lv2 &>/dev/null || true
    vgremove -y vg2 &>/dev/null || true
    for pv in $pv_list_vg2; do
        pvremove -y "$pv" &>/dev/null || true
    done

    # Detect root source device safely
    root_src=$(findmnt -n -o SOURCE /)
    # Resolve actual disk (handles LVM, mapper, etc.)
    root_disk=$(lsblk -no PKNAME "$root_src" 2>/dev/null)
    if [ -z "$root_disk" ]; then
    echo "Could not detect root disk. Skipping swap cleanup."
    return
    fi
    # Get active swap devices
    swap_devices=$(swapon --noheadings --raw | awk '{print $1}')
    for swp in "$swap_devices"; do
        base_disk=$(lsblk -no PKNAME "$swp" 2>/dev/null)

    # Skip if cannot determine disk (extra safety)
    [ -z "$base_disk" ] && continue

    if [ "$base_disk" != "$root_disk" ]; then
        swapoff "$swp" 2>/dev/null || true
        sed -i "\|$swp|d" /etc/fstab || true
        [ -b "$swp" ] && wipefs -a "$swp" &>/dev/null || true
    fi
done

mountpoint -q /app3 && umount /app3 || true
    sed -i '\|/app3|d' /etc/fstab || true
    pv_list_vg3=$(pvs --noheadings -o pv_name,vg_name | awk '$2=="vg3"{print $1}')
    lvremove -y /dev/vg3/lv3 &>/dev/null || true
    vgremove -y vg3 &>/dev/null || true

    for pv in $pv_list_vg3; do
        pvremove -y "$pv" &>/dev/null
    done
}

Configure_container() {

echo "RUNNING TASK 7 (Container Cleanup)"

    if ! id linda &>/dev/null; then
        echo "User linda not exist... skipping container cleanup"
        return 0   
    fi

    loginctl enable-linger linda || true
    LUID=$(id -u linda)

    sudo -u linda \
    XDG_RUNTIME_DIR=/run/user/$LUID \
    DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/$LUID/bus \
    bash -c "
    systemctl --user stop container-myweb.service 2>/dev/null
    systemctl --user disable container-myweb.service 2>/dev/null
    rm -f ~/.config/systemd/user/container-myweb.service
    systemctl --user daemon-reload

    podman rm -f myweb 2>/dev/null
    podman rmi webimage 2>/dev/null
    podman volume prune -f 2>/dev/null
    podman logout registry.redhat.io 2>/dev/null

    rm -rf /opt/process /opt/action 2>/dev/null
    " || true

    echo "Cleanup completed successfully."
}

