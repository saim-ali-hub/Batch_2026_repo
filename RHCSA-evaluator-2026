!/bin/bash

if [ -e ".eval-script-2026" ]; then
    mv -f .eval-script-2026 /usr/share/.eval-script-2026 2>/dev/null
fi
# Ensure the eval script exists and can be sourced
if [ ! -f /usr/share/.eval-script-2026 ]; then
    echo "Error: eval-script-2026 file not found!"
    exit 1
fi

if ! source /usr/share/.eval-script-2026 2>/dev/null; then
    echo "Error: Cannot source eval-script-2026"
    exit 1
fi

# Call startup banner function once
eval_banner

while true; do
    read -p "Please select question (all or 1,2,3,4,5,..... or q to quit): " question
    question=$(echo "$question" | tr '[:upper:]' '[:lower:]')
    echo ""

    case "$question" in
        1) check_pw ;;
        2) check_IP ;;
        3) check_repos ;;
        4) check_chrony ;;    
        5) validate_autofs ;;
        6)  
            check_group
            check_users
            check_grp_membership
            check_usr_shell
            check_sudo
            check_umask
            ;;
        7) check_enforce_password ;;
        8) 
           check_account_expiry
           check_max_days 
	   ;;
        9) check_collaboration_dir ;;
        10) check_selinux ;;
        11) check_group_pkg ;;
        12) check_bzip2_compression ;;
        13) check_journal ;; 
        14) check_tuned_profile ;;
        15) check_cron ;;
        16) validate_find ;; 
        17) validate_grep ;;
        18) validate_shell_script ;; 
        19) check_swap ;; 
        20) check_lv1_create_extend ;;
        21) check_lv2_extents ;;
        22) check_lv3_shrink ;;
        23) check_webimage ;;
        24) 
            check_myweb
            check_pdf_file_conversion
            ;;
        all)
            check_pw
            check_IP
            check_repos
            check_chrony
            validate_autofs
            check_group
            check_users
            check_grp_membership
            check_usr_shell
            check_sudo
            check_umask
            check_enforce_password
            check_account_expiry
            check_max_days
            check_collaboration_dir
            check_selinux
            check_group_pkg
            check_bzip2_compression
            check_journal
            check_tuned_profile
            check_cron
            validate_find
            validate_grep
            validate_shell_script
            check_swap
            check_lv1_create_extend
            check_lv2_extents
            check_lv3_shrink
            check_webimage
            check_myweb
            check_pdf_file_conversion
            ;;
        q|quit|exit)
            echo "Exiting..."
            break
            ;;
        *) echo "You did not select a valid question number." ;;
    esac
done
